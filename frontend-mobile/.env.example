# =============================================================================
# Badge System — Mobile App Environment Configuration
# =============================================================================
# Frontend configuration for React Native + Expo mobile app
#
# IMPORTANT: All variables must start with EXPO_PUBLIC_ to be accessible in mobile app
#
# Setup:
#   1. Copy this file: cp .env.example .env
#   2. Edit .env for your environment
#   3. Use: eas build --profile production
#
# Note: EXPO_PUBLIC_ variables are compiled into the app binary
# (they are public, so don't put secrets here)
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────
# API Configuration
# ─────────────────────────────────────────────────────────────────────────

# Backend API URL (where to send check-in requests)
# Local: http://localhost:3000 (Android only, iOS can't access localhost)
# Production: https://api.badge.dataxiom.it
EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

# API request timeout (in milliseconds)
EXPO_PUBLIC_API_TIMEOUT=30000

# ─────────────────────────────────────────────────────────────────────────
# Authentication (Auth0)
# ─────────────────────────────────────────────────────────────────────────

# Auth0 tenant domain
EXPO_PUBLIC_AUTH0_DOMAIN=your-auth0-domain.auth0.com

# Auth0 application Client ID (public)
EXPO_PUBLIC_AUTH0_CLIENT_ID=your_client_id_here

# Auth0 API audience
EXPO_PUBLIC_AUTH0_AUDIENCE=https://api.badge.dataxiom.it

# ─────────────────────────────────────────────────────────────────────────
# Application Configuration
# ─────────────────────────────────────────────────────────────────────────

# Application display name
EXPO_PUBLIC_APP_NAME=Badge System

# Application version
EXPO_PUBLIC_APP_VERSION=1.0.0

# Logging level: debug, info, warn, error
EXPO_PUBLIC_LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────────────────────────────────

# Enable Face ID biometric authentication
# true for iOS/Android with Face ID/biometric support
EXPO_PUBLIC_ENABLE_FACE_ID=true

# Enable offline check-in caching (Phase 2)
EXPO_PUBLIC_ENABLE_OFFLINE_CACHE=false

# ─────────────────────────────────────────────────────────────────────────
# Optional: Error Tracking (Sentry)
# ─────────────────────────────────────────────────────────────────────────

# Sentry DSN for mobile error tracking
EXPO_PUBLIC_SENTRY_DSN=

# Sentry environment
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development

# ─────────────────────────────────────────────────────────────────────────
# Development-Only
# ─────────────────────────────────────────────────────────────────────────

# Enable debug mode (verbose logging, dev menu visible)
EXPO_PUBLIC_DEBUG=true

# ─────────────────────────────────────────────────────────────────────────
# Environment-Specific Values
# ─────────────────────────────────────────────────────────────────────────
#
# Development (local testing):
#   EXPO_PUBLIC_API_URL=http://192.168.1.100:3000  (or actual IP)
#   EXPO_PUBLIC_LOG_LEVEL=debug
#   EXPO_PUBLIC_DEBUG=true
#
# Staging (TestFlight/Google Play internal):
#   EXPO_PUBLIC_API_URL=https://api-staging.badge.dataxiom.it
#   EXPO_PUBLIC_LOG_LEVEL=info
#   EXPO_PUBLIC_DEBUG=false
#
# Production (App Store/Google Play):
#   EXPO_PUBLIC_API_URL=https://api.badge.dataxiom.it
#   EXPO_PUBLIC_LOG_LEVEL=warn
#   EXPO_PUBLIC_DEBUG=false
#   EXPO_PUBLIC_SENTRY_DSN=<production-sentry-dsn>
#   EXPO_PUBLIC_SENTRY_ENVIRONMENT=production
#
# ─────────────────────────────────────────────────────────────────────────
