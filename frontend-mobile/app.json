{
  "expo": {
    "name": "Badge System",
    "slug": "badge-system",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A5F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "it.dataxiom.badge",
      "buildNumber": "19",
      "infoPlist": {
        "NSCameraUsageDescription": "Utilizzato per scansionare il QR code della sede",
        "NSFaceIDUsageDescription": "Utilizzato per autenticare il check-in",
        "NSPhotoLibraryUsageDescription": "Non utilizzato",
        "NSLocationWhenInUseUsageDescription": "La posizione GPS è richiesta per verificare che il check-in avvenga presso la sede di lavoro",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "it.dataxiom.badge",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1E3A5F"
      },
      "permissions": [
        "CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "updates": {
      "url": "https://u.expo.dev/7a913808-3c12-418c-ac23-59538898acff",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-updates",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Autorizza Badge System a usare Face ID per il check-in"
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Consenti a Badge System di usare la tua posizione per verificare il check-in presso la sede."
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "dataxium",
          "project": "badge-mobile"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "7a913808-3c12-418c-ac23-59538898acff"
      }
    },
    "owner": "dataxiom-badge"
  }
}
