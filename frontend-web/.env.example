# =============================================================================
# Badge System — Web Dashboard Environment Configuration
# =============================================================================
# Frontend configuration for React 18 + Vite dashboard
#
# IMPORTANT: This file is safe to commit (no secrets here).
# All variables must start with VITE_ to be exposed in browser.
#
# Setup:
#   1. Copy this file: cp .env.example .env
#   2. Edit .env for your environment (local, staging, production)
#   3. .env is automatically loaded by Vite
#
# Deployment:
#   - Netlify: Set environment variables in Netlify dashboard
#   - Local: npm run dev loads .env automatically
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────
# API Configuration
# ─────────────────────────────────────────────────────────────────────────

# Backend API URL (where to send requests)
# Local: http://localhost:3000
# Production: https://api.badge.dataxiom.it
VITE_API_URL=http://localhost:3000

# API request timeout (in milliseconds)
VITE_API_TIMEOUT=30000

# ─────────────────────────────────────────────────────────────────────────
# Authentication (Auth0)
# ─────────────────────────────────────────────────────────────────────────

# Auth0 tenant domain
# Example: badge.auth0.com
VITE_AUTH0_DOMAIN=your-auth0-domain.auth0.com

# Auth0 application Client ID (public, safe to expose)
VITE_AUTH0_CLIENT_ID=your_client_id_here

# OAuth callback URL (where Auth0 redirects after login)
# Local: http://localhost:5173/dashboard
# Production: https://dashboard.badge.dataxiom.it/dashboard
VITE_AUTH0_REDIRECT_URI=http://localhost:5173/dashboard

# Auth0 API audience (must match backend AUTH0_AUDIENCE)
VITE_AUTH0_AUDIENCE=https://api.badge.dataxiom.it

# ─────────────────────────────────────────────────────────────────────────
# Application Configuration
# ─────────────────────────────────────────────────────────────────────────

# Application display name
VITE_APP_NAME=Badge System

# Application version (for bug reports, analytics)
VITE_APP_VERSION=1.0.0

# Logging level: debug, info, warn, error
VITE_LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────────────────
# Build Configuration
# ─────────────────────────────────────────────────────────────────────────

# Enable source maps for debugging (disable in production)
VITE_SOURCEMAP=true

# ─────────────────────────────────────────────────────────────────────────
# Optional: Error Tracking (Sentry)
# ─────────────────────────────────────────────────────────────────────────

# Sentry DSN for error tracking (optional)
# Leave empty to disable error tracking
VITE_SENTRY_DSN=

# Sentry environment
VITE_SENTRY_ENVIRONMENT=development

# ─────────────────────────────────────────────────────────────────────────
# Optional: Analytics
# ─────────────────────────────────────────────────────────────────────────

# Google Analytics tracking ID (optional)
VITE_GOOGLE_ANALYTICS_ID=

# ─────────────────────────────────────────────────────────────────────────
# Environment-Specific Values
# ─────────────────────────────────────────────────────────────────────────
#
# Development (localhost):
#   VITE_API_URL=http://localhost:3000
#   VITE_AUTH0_REDIRECT_URI=http://localhost:5173/dashboard
#   VITE_LOG_LEVEL=debug
#
# Staging (AWS):
#   VITE_API_URL=https://api-staging.badge.dataxiom.it
#   VITE_AUTH0_REDIRECT_URI=https://dashboard-staging.badge.dataxiom.it/dashboard
#   VITE_LOG_LEVEL=info
#
# Production (AWS):
#   VITE_API_URL=https://api.badge.dataxiom.it
#   VITE_AUTH0_REDIRECT_URI=https://dashboard.badge.dataxiom.it/dashboard
#   VITE_LOG_LEVEL=error
#   VITE_SENTRY_DSN=<production-sentry-dsn>
#   VITE_SOURCEMAP=false
#
# ─────────────────────────────────────────────────────────────────────────
