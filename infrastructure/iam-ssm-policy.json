{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BadgeSSMReadProduction",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParametersByPath",
        "ssm:GetParameter",
        "ssm:GetParameters"
      ],
      "Resource": [
        "arn:aws:ssm:eu-west-1:*:parameter/badge/production",
        "arn:aws:ssm:eu-west-1:*:parameter/badge/production/*"
      ]
    },
    {
      "Sid": "BadgeKMSDecryptSSM",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "kms:ViaService": "ssm.eu-west-1.amazonaws.com"
        }
      }
    }
  ]
}
