# =============================================================================
# Badge System — Backend Environment Configuration
# =============================================================================
# IMPORTANT: Never commit the actual .env file (it contains secrets).
# This file is safe to commit — it's a template with example values.
#
# Setup:
#   1. Copy this file: cp .env.example .env
#   2. Edit .env with your actual values (database, Auth0 credentials, etc.)
#   3. Keep .env in .gitignore (already configured)
#   4. Never commit .env to git
#
# Validation: The backend validates all required variables on startup.
# If a variable is missing or invalid, the server will refuse to start
# with a clear error message showing what's wrong.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────
# 1. SERVER & LOGGING
# ─────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
APP_NAME=Badge System

# ─────────────────────────────────────────────────────────────────────────
# 2. DATABASE (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────

# Local: postgresql://badge_user:badge_pass@postgres:5432/badge_dev
# AWS RDS: postgresql://badge_user:password@hostname.rds.amazonaws.com:5432/badge_prod
DATABASE_URL=postgresql://badge_user:badge_pass@postgres:5432/badge_dev
DB_POOL_MIN=5
DB_POOL_MAX=10

# ─────────────────────────────────────────────────────────────────────────
# 3. AUTHENTICATION (Auth0)
# ─────────────────────────────────────────────────────────────────────────

AUTH0_DOMAIN=your-auth0-domain.auth0.com
AUTH0_CLIENT_ID=your_client_id_here
AUTH0_CLIENT_SECRET=your_client_secret_here
AUTH0_AUDIENCE=https://api.badge.dataxiom.it

# ─────────────────────────────────────────────────────────────────────────
# 4. JWT TOKENS
# ─────────────────────────────────────────────────────────────────────────

JWT_SECRET=your_jwt_secret_here_minimum_32_characters_required!!!
JWT_EXPIRY=30m
JWT_REFRESH_SECRET=your_refresh_secret_here_minimum_32_characters_required!!!
JWT_REFRESH_EXPIRY=7d

# ─────────────────────────────────────────────────────────────────────────
# 5. CORS & SECURITY
# ─────────────────────────────────────────────────────────────────────────

CORS_ORIGIN=http://localhost:5173,http://localhost:19000,http://localhost:3000
CORS_CREDENTIALS=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─────────────────────────────────────────────────────────────────────────
# 6. EXTERNAL SERVICES
# ─────────────────────────────────────────────────────────────────────────

SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ─────────────────────────────────────────────────────────────────────────
# 7. FEATURE FLAGS (Phase 1 = false)
# ─────────────────────────────────────────────────────────────────────────

ENABLE_OFFLINE_MODE=false
ENABLE_PAYROLL_API=false
ENABLE_WEBHOOKS=false

# ─────────────────────────────────────────────────────────────────────────
# 8. DEVELOPMENT-ONLY (set to false in production)
# ─────────────────────────────────────────────────────────────────────────

DISABLE_AUTH=false
SEED_TEST_DATA=false
MOCK_AUTH0=false

# ─────────────────────────────────────────────────────────────────────────
# 9. AWS (Optional)
# ─────────────────────────────────────────────────────────────────────────

AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=badge-exports-dev

# ─────────────────────────────────────────────────────────────────────────
# 10. EMAIL (Optional)
# ─────────────────────────────────────────────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@badge.dataxiom.it

# Sentry — Error Tracking (optional, server starts without it)
# Get DSN from: https://sentry.io → Project Settings → Client Keys
# Add to SSM: aws ssm put-parameter --name /badge/production/SENTRY_DSN --type SecureString --value <dsn> --region eu-west-1
SENTRY_DSN=

# ─────────────────────────────────────────────────────────────────────────
# 11. DEMO ACCOUNTS — badge.local internal users (C3 security fix)
# Passwords are read from env vars only — never hardcoded in source.
# In production: set in EC2 --env-file or AWS SSM Parameter Store.
# If a variable is not set, that demo account is disabled (cannot login).
# ─────────────────────────────────────────────────────────────────────────

DEMO_PIPPO_PASSWORD=change-me-in-production
DEMO_PINO_PASSWORD=change-me-in-production
DEMO_MARIA_PASSWORD=change-me-in-production
DEMO_LUCIA_PASSWORD=change-me-in-production

# ─────────────────────────────────────────────────────────────────────────
# 12. DATABASE SSL (C2 security fix)
# Defaults to true (validates RDS TLS certificate).
# Set to 'false' ONLY as a temporary fallback if the RDS CA is not in the
# system trust store. Never set false on a public endpoint.
# ─────────────────────────────────────────────────────────────────────────

DB_SSL_REJECT_UNAUTHORIZED=true
