{
  "name": "badge-system-backend",
  "version": "1.0.0",
  "description": "REST API for Badge System - retail attendance tracking with QR codes and Face ID",
  "author": "Diego Falletti",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "main": "src/app.js",
  "type": "commonjs",
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "./jest.setup.js"
    ]
  },
  "scripts": {
    "start": "NODE_ENV=production node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "format": "prettier --write 'src/**/*.js'",
    "migrations": "node src/db/migrations.js"
  },
  "dependencies": {
    "@sentry/node": "^10.56.0",
    "auth0": "^4.0.0",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "csv-stringify": "^6.4.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.10.0",
    "pino": "^8.15.0",
    "pino-http": "^9.0.0",
    "pino-pretty": "^10.2.0",
    "redis": "^4.6.0",
    "uuid": "^9.0.0",
    "zod": "^3.20.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.5",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "supertest": "^6.3.0"
  }
}
